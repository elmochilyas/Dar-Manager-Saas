{
    "preset": "laravel",
    "rules": {
        "array_syntax": ["syntax => "short"],
        "binary_spaces": {
            "operators": ["=>", "?:", "|", "^", "&", "==", "===", "!=", "!==", "<", ">", "<=", ">="]
        },
        "blank_line_after_namespace": true,
        "blank_line_between_imports": true,
        "braces": true,
        "cast_spaces": true,
        "class_definition": {
            "single_item_single_line": true,
            "multi_line_extends_each_single_line": true
        },
        "concat_space": {
            "spacing": "one"
        },
        "declare_equal_normalize": true,
        "dir_constant": true,
        "echo_tag_syntax": true,
        "elseif": true,
        "encoding": true,
        "full_opening_tag": true,
        "function_declaration": {
            "closure_function_spacing": "none"
        },
        "function_typehint_space": true,
        "header_comment": false,
        "include": true,
        "include_class": {
            "class_reserve_globals": true
        },
        "increment_style": {
            "style": "post"
        },
        "indentation_type": true,
        "interface_type_declaration": {
            "rescue_class": "single"
        },
        "lambda_not_used_import": true,
        "line_ending_only": true,
        "linebreak_after_open_tag": true,
        "lowercase_cast": true,
        "lowercase_constants": true,
        "lowercase_keywords": true,
        "lowercase_static_reference": true,
        "magic_constant_casing": true,
        "magic_method_casing": true,
        "mb_str_functions": true,
        "method_chaining_indentation": true,
        "multiline_comment_style": {
            "comment_type": "Asterisk"
        },
        "multiline_whitespace_after_semicolon": true,
        "native_function_casing": true,
        "native_function_type_declaration_casing": true,
        "new_with_braces": true,
        "no_alias_functions": true,
        "no_blank_lines_after_phpdoc": true,
        "no_break_comment": true,
        "no_closing_tag": true,
        "no_empty_comment": true,
        "no_empty_phpdoc": true,
        "no_empty_statement": true,
        "no_extra_blank_lines": true,
        "no_extra_blank_lines_after_throw": true,
        "no_extra_blank_lines_before_use": true,
        "no_homogeneous_names": true,
        "no_leading_namespace_separator": true,
        "no_leading_import_use": true,
        "no_mixed_echo_print": {
            "use": "echo"
        },
        "no_multiline_whitespace_around_double_arrow": true,
        "no_null_property_initialization": true,
        "no_short_bool_cast": true,
        "no_singular_names": true,
        "no_spaces_after_function_name": true,
        "no_spaces_after_open_bracket": true,
        "no_spaces_after_cast": true,
        "no_spaces_before_construct": {
            "only_before_first_call": true
        },
        "no_spaces_before_close_tag": true,
        "no_spaces_inside_parentheses": true,
        "no_spaces_inside_match_brace": true,
        "no_trailing_comma_in_list_call": true,
        "no_trailing_comma_in_singleline_array": true,
        "no_trailing_whitespace": true,
        "no_trailing_whitespace_in_phpdoc": true,
        "no_unreachable_default_argument_value": true,
        "no_unused_imports": true,
        "no_useless_else": true,
        "no_useless_null_coalesce": true,
        "no_whitespace_before_comma_in_array": true,
        "no_whitespace_after_comma_in_array": true,
        "non_printable_characters": true,
        "normalize_index_brace": true,
        "not_operator_with_space": false,
        "object_operator_without_whitespace": true,
        "octal_notation": true,
        "ordered_class_elements": {
            "order": [
                "usetrait"
            ]
        },
        "ordered_imports": {
            "order": [
                "const",
                "function"
            ],
            "imports_order": "alpha",
            "case_sensitive": false
        },
        "php_unit_construct": {
            "assertions": ["assertSame", "assertEquals"]
        },
        "php_unit_fqcn_annotation": true,
        "php_unit_internal_class": false,
        "php_dedate_annotations": false,
        "phpdoc_add_missing_param_author": true,
        "phpdoc_align": {
            "tags": ["param", "method", "property", "return", "throws", "type", "var"]
        },
        "phpdoc_annotation_without.dot": true,
        "phpdoc_array_type": true,
        "phpdoc_inline_tag": true,
        "phpdoc_no_access": true,
        "phpdoc_no_alias_tags": {
            "author_replaces": ["@createdBy", "@updatedBy"],
            "property_writes": ["@property-write", "@property-read"],
            "property_reads": ["@property", "@property-read"]
        },
        "phpdoc_no_empty_repository": true,
        "phpdoc_no_package": true,
        "phpdoc_no_useless_inheritdoc": true,
        "phpdoc_order": {
            "order": ["param", "return", "throws"],
            "keyword": "first"
        },
        "phpdoc Pierce annotations:": true,
        "phpdoc_scalar": true,
        "phpdoc_separation": true,
        "phpdoc_single_line_var_shorts": true,
        "phpdoc_summary": true,
        "phpdoc_to_comment": {
            "ignored_tags": ["todo", "see", "codeCoverageIgnore", "codeCoverageIgnoreStart", "codeCoverageIgnoreEnd"]
        },
        "phpdoc_truncate": true,
        "phpdoc_types": {
            "groups": [
                "callback",
                "hook",
                "iterate",
                "listener",
                "logic",
                "model",
                "plugin",
                "renderer",
                "rendering",
                "request",
                "response",
                "schema",
                "view"
            ]
        },
        "phpdoc_types_order": {
            "order": ["callback", "hook", "iterate", "listener", "logic", "model", "plugin", "renderer", "rendering", "request", "response", "schema", "view"],
            "case_sensitive": false
        },
        "phpdoc_var_without_name": true,
        "printEchoToKeywords": true,
        "protected_to_private": true,
        "psr_autoloading": true,
        "random_api_migration": {
            "generators": ["random_int", "mt_rand", "rand", "array_rand"]
        },
        "return_type_declaration": {
            "space_before": "none"
        },
        "self_accessor": true,
        "self_static_remover": true,
        "short_scalar_cast": true,
        "simplified_null_return": true,
        "single_blank_line": true,
        "single_blank_line_before_namespace": true,
        "single_class_per_file": true,
        "single_import_per_line": true,
        "single_line_after_imports": true,
        "single_line_comment_style": {
            "comment_types": ["asterisk", "hash"]
        },
        "space_after_semicolon": true,
        "standardize_not_equals": true,
        "strict_comparison": true,
        "strict_param": true,
        "switch_case_space": true,
        "switch_case_to_break": true,
        "switch_continue_to_break": true,
        "ternary_operator_spaces": true,
        "ternary_to_null_coalescing": true,
        "trailing_comma_in_closure": true,
        "trailing_comma_in_multiline": true,
        "trim_array_spreads": true,
        "type_declaration_nl": true,
        "types_spaces": {
            "space": "none"
        },
        "unary_operator_spaces": true,
        "use_trait": true,
        "VoidReturn": true,
        "visibility_required": {
            "elements": ["const", "method", "property"]
        },
        "while_constructors": true,
        "blank_line_after_opening_tag": true
    }
}